   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv(\"data/sales.csv\",usecols=['订单号',\"产品类别\",'产品名称','销售数量','单价'])\n",
    "\n",
    "# 数据梳理 添加一列 销售金额\n",
    "df['销售金额'] = df['销售数量'] * df['单价']\n",
    "\n",
    "df.to_csv(\"data/sales_new.csv\",index=False)"
   ],
